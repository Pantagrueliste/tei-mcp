<?xml version="1.0" encoding="UTF-8"?>
<schemaSpec xmlns="http://www.tei-c.org/ns/1.0" ident="tei_test" start="TEI">

  <!-- Element Specs -->
  <elementSpec ident="p" module="core">
    <gloss xml:lang="en">paragraph</gloss>
    <gloss xml:lang="de">Absatz</gloss>
    <desc xml:lang="en">marks paragraphs in prose.</desc>
    <desc xml:lang="de">bezeichnet Absaetze in Prosa.</desc>
    <classes>
      <memberOf key="model.pLike"/>
      <memberOf key="att.global"/>
    </classes>
    <attList>
      <attDef ident="part" usage="opt">
        <desc xml:lang="en">specifies whether or not the paragraph is complete.</desc>
        <datatype><dataRef key="teidata.enumerated"/></datatype>
        <valList type="closed">
          <valItem ident="Y"><desc xml:lang="en">yes</desc></valItem>
          <valItem ident="N"><desc xml:lang="en">no</desc></valItem>
          <valItem ident="I"><desc xml:lang="en">initial</desc></valItem>
          <valItem ident="M"><desc xml:lang="en">medial</desc></valItem>
          <valItem ident="F"><desc xml:lang="en">final</desc></valItem>
        </valList>
      </attDef>
      <attDef ident="rend" usage="opt">
        <desc xml:lang="en">indicates how the element in question was rendered or presented in the source text.</desc>
        <datatype><dataRef key="teidata.word"/></datatype>
        <valList type="semi">
          <valItem ident="italic"><desc xml:lang="en">italic</desc></valItem>
          <valItem ident="bold"><desc xml:lang="en">bold</desc></valItem>
          <valItem ident="underline"><desc xml:lang="en">underline</desc></valItem>
          <valItem ident="strikethrough"><desc xml:lang="en">strikethrough</desc></valItem>
        </valList>
      </attDef>
    </attList>
    <content>
      <macroRef key="macro.paraContent"/>
    </content>
  </elementSpec>

  <elementSpec ident="persName" module="namesdates">
    <gloss xml:lang="en">personal name</gloss>
    <desc xml:lang="en">contains a proper noun or proper-noun phrase referring to a person.</desc>
    <classes>
      <memberOf key="model.nameLike.agent"/>
      <memberOf key="att.global"/>
      <memberOf key="att.naming"/>
    </classes>
    <attList>
      <attDef ident="type" usage="opt">
        <desc xml:lang="en">indicates a more specific type of personal name.</desc>
        <datatype><dataRef key="teidata.text"/></datatype>
      </attDef>
      <attDef ident="ref" usage="opt">
        <desc xml:lang="en">provides a reference to a canonical identifier for the person.</desc>
        <datatype><dataRef name="anyURI"/></datatype>
      </attDef>
    </attList>
    <content>
      <alternate minOccurs="0" maxOccurs="unbounded">
        <textNode/>
        <classRef key="model.gLike"/>
        <elementRef key="surname"/>
        <elementRef key="forename"/>
        <elementRef key="roleName"/>
      </alternate>
    </content>
  </elementSpec>

  <elementSpec ident="div" module="textstructure">
    <gloss xml:lang="en">text division</gloss>
    <desc xml:lang="en">contains a subdivision of the front, body, or back of a text.</desc>
    <classes>
      <memberOf key="model.divLike"/>
      <memberOf key="att.global"/>
    </classes>
    <attList>
      <attDef ident="type" usage="opt">
        <desc xml:lang="en">characterizes the element in some sense.</desc>
      </attDef>
    </attList>
    <content>
      <sequence>
        <alternate minOccurs="0" maxOccurs="unbounded">
          <classRef key="model.divTop"/>
          <classRef key="model.global"/>
        </alternate>
        <sequence minOccurs="1" maxOccurs="1">
          <alternate minOccurs="1" maxOccurs="1">
            <sequence minOccurs="1" maxOccurs="unbounded">
              <classRef key="model.divLike"/>
            </sequence>
            <sequence minOccurs="1" maxOccurs="unbounded">
              <classRef key="model.common"/>
            </sequence>
          </alternate>
        </sequence>
      </sequence>
    </content>
  </elementSpec>

  <elementSpec ident="body" module="textstructure">
    <gloss xml:lang="en">text body</gloss>
    <desc xml:lang="en">contains the whole body of a single unitary text.</desc>
    <classes>
      <memberOf key="att.global"/>
    </classes>
    <content>
      <sequence>
        <classRef key="model.common" minOccurs="1" maxOccurs="unbounded"/>
      </sequence>
    </content>
  </elementSpec>

  <elementSpec ident="head" module="core">
    <gloss xml:lang="en">heading</gloss>
    <desc xml:lang="en">contains any type of heading.</desc>
    <classes>
      <memberOf key="model.divTop"/>
      <memberOf key="att.global"/>
    </classes>
    <content>
      <alternate minOccurs="0" maxOccurs="unbounded">
        <textNode/>
        <classRef key="model.phrase"/>
      </alternate>
    </content>
  </elementSpec>

  <elementSpec ident="hi" module="core">
    <gloss xml:lang="en">highlighted</gloss>
    <desc xml:lang="en">marks a word or phrase as graphically distinct.</desc>
    <classes>
      <memberOf key="model.phrase"/>
      <memberOf key="att.global"/>
    </classes>
    <content>
      <macroRef key="macro.paraContent"/>
    </content>
  </elementSpec>

  <elementSpec ident="note" module="core">
    <gloss xml:lang="en">note</gloss>
    <desc xml:lang="en">contains a note or annotation.</desc>
    <classes>
      <memberOf key="model.global"/>
      <memberOf key="att.global"/>
    </classes>
    <content>
      <macroRef key="macro.paraContent"/>
    </content>
  </elementSpec>

  <elementSpec ident="gap" module="core">
    <gloss xml:lang="en">gap</gloss>
    <desc xml:lang="en">indicates a point where material has been omitted.</desc>
    <classes>
      <memberOf key="model.global"/>
      <memberOf key="att.global"/>
    </classes>
    <content>
      <empty/>
    </content>
  </elementSpec>

  <elementSpec ident="gi" module="tagdocs">
    <gloss xml:lang="en">element name</gloss>
    <desc xml:lang="en">contains the name of an element.</desc>
    <classes>
      <memberOf key="att.global"/>
    </classes>
    <content>
      <dataRef key="teidata.name"/>
    </content>
  </elementSpec>

  <elementSpec ident="surname" module="namesdates">
    <gloss xml:lang="en">surname</gloss>
    <desc xml:lang="en">contains a family name.</desc>
    <classes>
      <memberOf key="model.nameLike"/>
      <memberOf key="att.global"/>
    </classes>
    <content>
      <alternate minOccurs="0" maxOccurs="unbounded">
        <textNode/>
        <classRef key="model.gLike"/>
      </alternate>
    </content>
  </elementSpec>

  <elementSpec ident="forename" module="namesdates">
    <gloss xml:lang="en">forename</gloss>
    <desc xml:lang="en">contains a forename or given name.</desc>
    <classes>
      <memberOf key="model.nameLike"/>
      <memberOf key="att.global"/>
    </classes>
    <content>
      <alternate minOccurs="0" maxOccurs="unbounded">
        <textNode/>
        <classRef key="model.gLike"/>
      </alternate>
    </content>
  </elementSpec>

  <elementSpec ident="roleName" module="namesdates">
    <gloss xml:lang="en">role name</gloss>
    <desc xml:lang="en">contains a name component which indicates that the referent has a particular role or position in society.</desc>
    <classes>
      <memberOf key="model.nameLike"/>
      <memberOf key="att.global"/>
    </classes>
    <content>
      <alternate minOccurs="0" maxOccurs="unbounded">
        <textNode/>
      </alternate>
    </content>
  </elementSpec>

  <!-- Class Specs -->
  <classSpec ident="model.common" module="tei" type="model">
    <gloss xml:lang="en">common model elements</gloss>
    <desc xml:lang="en">groups common model elements.</desc>
  </classSpec>

  <classSpec ident="model.pLike" module="core" type="model">
    <gloss xml:lang="en">paragraph-like elements</gloss>
    <desc xml:lang="en">groups paragraph-like elements.</desc>
    <classes>
      <memberOf key="model.common"/>
    </classes>
  </classSpec>

  <classSpec ident="model.divTop" module="textstructure" type="model">
    <gloss xml:lang="en">division-top elements</gloss>
    <desc xml:lang="en">groups elements appearing at the top of a text division.</desc>
  </classSpec>

  <classSpec ident="model.global" module="tei" type="model">
    <gloss xml:lang="en">globally-available elements</gloss>
    <desc xml:lang="en">groups elements available in all TEI documents.</desc>
  </classSpec>

  <classSpec ident="model.phrase" module="tei" type="model">
    <gloss xml:lang="en">phrase-level elements</gloss>
    <desc xml:lang="en">groups phrase-level elements.</desc>
  </classSpec>

  <classSpec ident="model.inter" module="tei" type="model">
    <gloss xml:lang="en">inter-level elements</gloss>
    <desc xml:lang="en">groups inter-level elements.</desc>
  </classSpec>

  <classSpec ident="model.gLike" module="tei" type="model">
    <gloss xml:lang="en">glyph-like elements</gloss>
    <desc xml:lang="en">groups elements used to represent non-standard characters or glyphs.</desc>
  </classSpec>

  <classSpec ident="model.nameLike.agent" module="tei" type="model">
    <gloss xml:lang="en">agent name-like elements</gloss>
    <desc xml:lang="en">groups elements that refer to named agents.</desc>
    <classes>
      <memberOf key="model.nameLike"/>
    </classes>
  </classSpec>

  <classSpec ident="model.nameLike" module="tei" type="model">
    <gloss xml:lang="en">name-like elements</gloss>
    <desc xml:lang="en">groups elements that contain names.</desc>
    <classes>
      <memberOf key="model.phrase"/>
    </classes>
  </classSpec>

  <classSpec ident="model.divLike" module="textstructure" type="model">
    <gloss xml:lang="en">division-like elements</gloss>
    <desc xml:lang="en">groups elements used to represent divisions of a text.</desc>
  </classSpec>

  <classSpec ident="att.global" module="tei" type="atts">
    <gloss xml:lang="en">globally-available attributes</gloss>
    <desc xml:lang="en">provides attributes common to all elements in the TEI encoding scheme.</desc>
    <classes/>
    <attList>
      <attDef ident="xml:id" usage="opt">
        <desc xml:lang="en">provides a unique identifier for the element.</desc>
        <datatype><dataRef key="ID"/></datatype>
      </attDef>
      <attDef ident="n" usage="opt">
        <desc xml:lang="en">gives a number or similar label for an element.</desc>
        <datatype><dataRef key="teidata.text"/></datatype>
      </attDef>
    </attList>
  </classSpec>

  <classSpec ident="att.naming" module="namesdates" type="atts">
    <gloss xml:lang="en">naming attributes</gloss>
    <desc xml:lang="en">provides attributes for naming entities.</desc>
    <classes>
      <memberOf key="att.canonical"/>
    </classes>
    <attList>
      <attDef ident="role" usage="opt">
        <desc xml:lang="en">specifies a primary role for the person.</desc>
        <datatype><dataRef key="teidata.enumerated"/></datatype>
        <valList type="semi">
          <valItem ident="author"><desc xml:lang="en">author</desc></valItem>
          <valItem ident="editor"><desc xml:lang="en">editor</desc></valItem>
        </valList>
      </attDef>
    </attList>
  </classSpec>

  <classSpec ident="att.canonical" module="tei" type="atts">
    <gloss xml:lang="en">canonical reference attributes</gloss>
    <desc xml:lang="en">provides attributes for canonical references.</desc>
    <classes/>
    <attList>
      <attDef ident="ref" usage="opt">
        <desc xml:lang="en">provides an explicit means of locating a full definition or identity for the entity being named.</desc>
        <datatype><dataRef key="teidata.pointer"/></datatype>
      </attDef>
    </attList>
  </classSpec>

  <!-- Deprecated Element Specs -->
  <elementSpec ident="re" module="dictionaries" validUntil="2024-01-15">
    <gloss xml:lang="en">related entry</gloss>
    <desc xml:lang="en">contains a dictionary entry for a lexical item related to the headword.</desc>
    <desc xml:lang="en" type="deprecationInfo">Because an <gi>entry</gi> can now occur inside an <gi>entry</gi>, the <gi>re</gi> element is no longer needed.</desc>
    <classes>
      <memberOf key="model.common"/>
    </classes>
    <content/>
  </elementSpec>

  <elementSpec ident="superEntry" module="dictionaries" validUntil="2027-03-07">
    <gloss xml:lang="en">super entry</gloss>
    <desc xml:lang="en">groups a sequence of entries within any kind of lexical resource.</desc>
    <classes>
      <memberOf key="model.common"/>
    </classes>
    <content/>
  </elementSpec>

  <!-- Class with deprecated attDef -->
  <classSpec ident="att.ref" module="tei" type="atts">
    <gloss xml:lang="en">reference attributes</gloss>
    <desc xml:lang="en">provides attributes for referencing.</desc>
    <classes/>
    <attList>
      <attDef ident="name" usage="opt" validUntil="2026-11-13">
        <desc xml:lang="en">specifies a name for the referent.</desc>
        <desc xml:lang="en" type="deprecationInfo">Use the <att>ident</att> attribute instead.</desc>
        <datatype><dataRef key="teidata.text"/></datatype>
      </attDef>
    </attList>
  </classSpec>

  <elementSpec ident="attRef" module="tagdocs">
    <gloss xml:lang="en">attribute reference</gloss>
    <desc xml:lang="en">references an attribute.</desc>
    <classes>
      <memberOf key="att.ref"/>
      <memberOf key="att.global"/>
    </classes>
    <content/>
  </elementSpec>

  <elementSpec ident="egXML" module="tagdocs">
    <gloss xml:lang="en">example XML</gloss>
    <desc xml:lang="en">contains a single well-formed XML example demonstrating the use of some element or attribute.</desc>
    <classes>
      <memberOf key="att.global"/>
    </classes>
    <content>
      <alternate minOccurs="0" maxOccurs="unbounded">
        <textNode/>
        <anyElement/>
      </alternate>
    </content>
  </elementSpec>

  <!-- Macro Spec -->
  <macroSpec ident="macro.paraContent" module="core">
    <gloss xml:lang="en">paragraph content</gloss>
    <desc xml:lang="en">defines the content of paragraphs and similar elements.</desc>
    <content>
      <alternate minOccurs="0" maxOccurs="unbounded">
        <textNode/>
        <classRef key="model.gLike"/>
        <classRef key="model.phrase"/>
        <classRef key="model.inter"/>
        <classRef key="model.global"/>
      </alternate>
    </content>
  </macroSpec>

  <!-- Module Specs -->
  <moduleSpec ident="core">
    <gloss xml:lang="en">core module</gloss>
    <desc xml:lang="en">provides elements available in all TEI documents.</desc>
  </moduleSpec>

  <moduleSpec ident="namesdates">
    <gloss xml:lang="en">names and dates</gloss>
    <desc xml:lang="en">provides elements for names of persons, places, and organizations, and for dates and times.</desc>
  </moduleSpec>

  <moduleSpec ident="textstructure">
    <gloss xml:lang="en">text structure</gloss>
    <desc xml:lang="en">provides elements for the default structure of TEI texts.</desc>
  </moduleSpec>

  <moduleSpec ident="tagdocs">
    <gloss xml:lang="en">tag documentation</gloss>
    <desc xml:lang="en">provides elements for documenting markup languages.</desc>
  </moduleSpec>

</schemaSpec>
